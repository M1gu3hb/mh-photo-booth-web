# Copy to .env.local for dev, or set in Vercel Project Settings for prod.

# API key the desktop software must send (header x-api-key) to upload/create events.
UPLOAD_API_KEY=

# Vercel Blob token (media storage in production). Added automatically when you
# create a Blob store in the Vercel dashboard. Without it, dev uses local ./.data.
BLOB_READ_WRITE_TOKEN=
# Public base URL of the Blob store (to read JSON index in prod), e.g.
# https://<id>.public.blob.vercel-storage.com
BLOB_PUBLIC_BASE_URL=

# Public site URL (used to build folio links / QR targets).
NEXT_PUBLIC_SITE_URL=
